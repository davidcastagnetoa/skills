{
  "expo": {
    "name": "VerifID",
    "slug": "verifid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.advantra.verifid",
      "infoPlist": {
        "NSCameraUsageDescription": "VerifID needs camera access to capture your selfie and document for identity verification.",
        "NSPhotoLibraryUsageDescription": "Not used — camera only."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a73e8"
      },
      "package": "com.advantra.verifid",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "VerifID needs camera access for identity verification."
        }
      ]
    ]
  }
}
